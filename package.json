{
  "name": "nolia",
  "version": "0.1.0",
  "private": true,
  "description": "Nolia local-first Markdown knowledge workstation",
  "author": "Nolia Contributors",
  "license": "GPL-3.0-or-later",
  "main": "dist/main/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k -n main,renderer,electron -c blue,green,magenta \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsup --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on dist/main/index.js http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsup",
    "build:renderer": "vite build",
    "verify:release": "node build/verifyReleaseEnv.cjs",
    "package": "npm run verify:release && npm run build && electron-builder --mac --universal --publish never",
    "package:unsigned": "npm run build && NOLIA_SKIP_NOTARIZE=1 CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --universal --publish never",
    "package:linux": "npm run build && electron-builder --linux --publish never",
    "package:linux:dir": "npm run build && electron-builder --linux --dir --publish never",
    "package:win": "npm run build && node build/withWinPackagingEnv.cjs",
    "package:win:dir": "npm run build && node build/withWinPackagingEnv.cjs --dir",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test"
  },
  "build": {
    "appId": "com.nolia.app",
    "productName": "Nolia",
    "asar": true,
    "compression": "maximum",
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "docs",
        "to": "docs"
      },
      {
        "from": "LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "SECURITY.md",
        "to": "SECURITY.md"
      },
      {
        "from": "CONTRIBUTING.md",
        "to": "CONTRIBUTING.md"
      }
    ],
    "directories": {
      "output": "release"
    },
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Office",
      "maintainer": "Nolia Contributors <ailehuoquan@163.com>",
      "description": "Nolia local-first Markdown knowledge workstation",
      "extraResources": [
        {
          "from": "build/icon.png",
          "to": "assets/icon.png"
        }
      ],
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "compression": "normal",
      "signAndEditExecutable": false,
      "signExts": [
        "!.exe"
      ],
      "extraResources": [
        {
          "from": "build/icon.ico",
          "to": "assets/icon.ico"
        }
      ],
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nolia"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "role": "Editor"
      }
    ],
    "afterSign": "build/afterSign.cjs",
    "afterPack": "build/afterPack.cjs"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@tiptap/extension-code-block-lowlight": "3.23.6",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-table": "^3.23.6",
    "@tiptap/extension-task-item": "^3.23.6",
    "@tiptap/extension-task-list": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@uiw/react-codemirror": "^4.25.10",
    "chokidar": "^5.0.0",
    "katex": "^0.17.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.16.0",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.15.0",
    "mime-types": "^3.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-parse": "^9.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-remark": "^10.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "sanitize-filename": "^1.6.4",
    "sql.js": "^1.14.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "resedit": "^1.7.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "tmp": "^0.2.6"
  }
}
